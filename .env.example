# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional: REST model for screen→file export (.xlsx chart data and .txt text) — default gemini-2.5-flash-lite.
# If your quota is on Gemini 3 Flash instead, try: GEMINI_CHART_EXTRACT_MODEL=gemini-3-flash-preview
# GEMINI_CHART_EXTRACT_MODEL=gemini-2.5-flash-lite

# Optional: REST model for long-term memory consolidation (same default as chart extract).
# GEMINI_MEMORY_MODEL=gemini-2.5-flash-lite

# Optional: REST model for screen → Google Maps link (defaults to GEMINI_CHART_EXTRACT_MODEL or gemini-2.5-flash-lite).
# GEMINI_MAPS_EXTRACT_MODEL=gemini-2.5-flash-lite

# Optional: Google Calendar — create events via OAuth (Desktop client in Google Cloud Console).
# Redirect URI must match Console: default below, or set GOOGLE_OAUTH_REDIRECT_URI to the same value you registered.
# GOOGLE_OAUTH_CLIENT_ID=....apps.googleusercontent.com
# GOOGLE_OAUTH_CLIENT_SECRET=GOCSPX-...
# GOOGLE_OAUTH_REDIRECT_URI=http://127.0.0.1:45231/oauth2callback
