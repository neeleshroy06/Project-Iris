# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=your_key_here

# Optional: REST model for screen→file export (.xlsx chart data and .txt text) — default gemini-2.5-flash-lite.
# If your quota is on Gemini 3 Flash instead, try: GEMINI_CHART_EXTRACT_MODEL=gemini-3-flash-preview
# GEMINI_CHART_EXTRACT_MODEL=gemini-2.5-flash-lite
